<section class="chapter chapter--light about-section" id="leadership" data-page-panel="leadership">
  <div class="container">
    <header class="chapter__head">
      <span class="chapter__num reveal">09</span>
      <p class="eyebrow reveal">
        <span class="lang en">Our Leadership</span>
        <span class="lang vi">Ban lãnh đạo</span>
        <span class="lang zh">领导团队</span>
      </p>
      <h2 class="chapter__title chapter__title--sm">
        <span class="lang en">
          <span class="line-mask"><span class="line">Leadership That</span></span>
          <span class="line-mask"><span class="line line--muted">Steers the Group.</span></span>
        </span>
        <span class="lang vi">
          <span class="line-mask"><span class="line">Ban lãnh đạo</span></span>
          <span class="line-mask"><span class="line line--muted">định hướng Tập đoàn.</span></span>
        </span>
        <span class="lang zh">
          <span class="line-mask"><span class="line">以领导力</span></span>
          <span class="line-mask"><span class="line line--muted">掌舵集团。</span></span>
        </span>
      </h2>
      <p class="chapter__desc reveal" data-delay="200">
        <span class="lang en">Seasoned executives across Group companies set strategy, capital discipline and operating standards for Nam Viet’s agribusiness ecosystem — from nutrition and manufacturing to trade and logistics.</span>
        <span class="lang vi">Đội ngũ lãnh đạo dày dặn tại các công ty thành viên định hướng chiến lược, kỷ luật vốn và chuẩn vận hành cho hệ sinh thái nông nghiệp Nam Việt — từ dinh dưỡng, sản xuất đến thương mại và logistics.</span>
        <span class="lang zh">集团及成员企业高管团队负责战略定调、资本纪律与运营标准，支撑南越农业产业生态——覆盖营养方案、制造、贸易与物流。</span>
      </p>
    </header>

    {% set rosterCompact = true %}
    {% include "partials/leadership-roster.njk" %}

    <div class="center reveal" data-delay="200">
      <a class="btn btn--dark" href="{{ '/about/leadership/' | url }}">
        <span class="btn__dot"></span>
        <span class="lang en">View the full leadership roster</span>
        <span class="lang vi">Xem toàn bộ ban lãnh đạo</span>
        <span class="lang zh">查看完整领导名录</span>
      </a>
    </div>
  </div>
</section>

{% if ecosystem and ecosystem.sectors and ecosystem.sectors.length %}
