<!-- ═════════════ 10 · MILESTONES / JOURNEY ═════════════ -->
<section class="chapter chapter--cream chapter--journey" id="milestones" data-chapter="10" data-label-en="JOURNEY" data-label-zh="发展历程" data-label-vi="HÀNH TRÌNH">
  <div class="container">
    {# Title form matches Leadership; content body follows journey mockup #}
    <header class="journey__head">
      <span class="chapter__num reveal">10</span>
      <p class="eyebrow reveal"><span class="lang en">Our Journey</span><span class="lang vi">Hành trình phát triển</span><span class="lang zh">发展历程</span></p>
      <h2 class="chapter__title chapter__title--sm">
        <span class="lang en">
          <span class="line-mask"><span class="line">Milestones That</span></span>
          <span class="line-mask"><span class="line line--muted">Built Who We Are.</span></span>
        </span>
        <span class="lang vi">
          <span class="line-mask"><span class="line">Những cột mốc</span></span>
          <span class="line-mask"><span class="line line--muted">làm nên Nam Việt.</span></span>
        </span>
        <span class="lang zh">
          <span class="line-mask"><span class="line">里程碑</span></span>
          <span class="line-mask"><span class="line line--muted">铸就南越。</span></span>
        </span>
      </h2>
      {% if journey and journey.intro %}
      <p class="journey__intro reveal" data-delay="150">
        <span class="lang en">{{ journey.intro.en }}</span>
        <span class="lang vi">{{ journey.intro.vi }}</span>
        <span class="lang zh">{{ journey.intro.zh }}</span>
      </p>
      {% endif %}
      <span class="journey__rule reveal" data-delay="200" aria-hidden="true"></span>
    </header>

    {% if journey and journey.items and (journey.items | length) %}
    <div class="journey-tl" data-journey-tl>
      <div class="journey-tl__controls">
        <button type="button" class="journey-tl__nav" data-journey-prev aria-controls="journeyTrack">
          <span class="visually-hidden"><span class="lang en">Previous milestones</span><span class="lang vi">Cột mốc trước</span><span class="lang zh">上一里程碑</span></span>
          <span aria-hidden="true">←</span>
        </button>
        <button type="button" class="journey-tl__nav" data-journey-next aria-controls="journeyTrack">
          <span class="visually-hidden"><span class="lang en">Next milestones</span><span class="lang vi">Cột mốc sau</span><span class="lang zh">下一里程碑</span></span>
          <span aria-hidden="true">→</span>
        </button>
      </div>
      <div class="journey-tl__stage">
      <div class="journey-tl__rail" aria-hidden="true"><span class="journey-tl__fill" id="timelineFill"></span></div>
      <ol class="journey-tl__track" id="journeyTrack" tabindex="0">
        {% for item in journey.items %}
        <li class="jcard{% if loop.first %} is-active{% endif %} reveal" data-delay="{{ loop.index0 * 70 }}" data-year="{{ item.year }}">
          <div class="jcard__meta">
            <span class="jcard__marker" aria-hidden="true"><span></span></span>
          </div>
          <article class="jcard__panel">
            {% if item.file %}
            <div class="jcard__media">
              <img
                src="{{ ('/assets/img/milestones/' ~ item.file) | url }}"
                alt="{{ item.en.title }}"
                loading="lazy"
                width="960"
                height="1200"
                decoding="async"
              >
            </div>
            {% endif %}
            <div class="jcard__veil" aria-hidden="true"></div>
            <span class="jcard__year" aria-hidden="true">{{ item.year }}</span>
            <div class="jcard__copy">
              <span class="jcard__icon" aria-hidden="true">
                {% if item.icon == "building" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 21V5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v16M14 21V10a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v11M2 21h20M8 8h2M8 12h2M8 16h2M17 13h1M17 17h1"/></svg>
                {% elif item.icon == "farm" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 20c2-4 4-7 8-7s6 3 8 7M8 10c0-2.2 1.8-4 4-4s4 1.8 4 4M9 20v-3h6v3"/></svg>
                {% elif item.icon == "lab" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 3h6M10 3v6.5L5.5 18a2.5 2.5 0 0 0 2.2 3.5h8.6a2.5 2.5 0 0 0 2.2-3.5L14 9.5V3M8.5 14h7"/></svg>
                {% elif item.icon == "warehouse" %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 10.5 12 4l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-9.5ZM7 21v-7h10v7"/></svg>
                {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
                {% endif %}
              </span>
              <h3 class="jcard__title">
                <span class="lang en">{{ item.en.title }}</span>
                <span class="lang vi">{{ item.vi.title }}</span>
                <span class="lang zh">{{ item.zh.title }}</span>
              </h3>
              <p class="jcard__text">
                <span class="lang en">{{ item.en.text }}</span>
                <span class="lang vi">{{ item.vi.text }}</span>
                <span class="lang zh">{{ item.zh.text }}</span>
              </p>
            </div>
          </article>
        </li>
        {% endfor %}
      </ol>
      </div>
    </div>
    {% endif %}

    {% if journey and journey.banner and journey.banner.file %}
    <aside class="journey-banner reveal" data-delay="120">
      <div class="journey-banner__media">
        <img src="{{ ('/assets/img/milestones/' ~ journey.banner.file) | url }}" alt="Nam Viet agricultural landscape" loading="lazy" width="1920" height="820" decoding="async">
      </div>
      <div class="journey-banner__overlay" aria-hidden="true"></div>
      <div class="journey-banner__inner">
        <div class="journey-banner__cta">
          <span class="journey-banner__sprout" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="30" fill="#1d6a3e"/>
              <path d="M32 46V28M32 28c0-8 6-14 14-14-1 10-6 14-14 14Zm0 0c0-8-6-14-14-14 1 10 6 14 14 14Z" stroke="#f4f1ea" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <p>
            <span class="lang en">{{ journey.banner.statement.en }}</span>
            <span class="lang vi">{{ journey.banner.statement.vi }}</span>
            <span class="lang zh">{{ journey.banner.statement.zh }}</span>
          </p>
        </div>
        {% if journey.banner.stats %}
        <ul class="journey-banner__stats">
          {% for stat in journey.banner.stats %}
          <li>
            <span class="journey-stat__icon" aria-hidden="true">
              {% if stat.icon == "years" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/></svg>
              {% elif stat.icon == "companies" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="9" cy="8" r="3"/><circle cx="16" cy="9" r="2.5"/><path d="M3 19c1-3 3.5-4.5 6-4.5S14 16 15 19M14 14.5c2-.2 4 1 5 3.5"/></svg>
              {% elif stat.icon == "projects" %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M4 7h16v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z"/></svg>
              {% else %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 19V5M4 19h16M8 16V10M12 16V7M16 16v-4"/></svg>
              {% endif %}
            </span>
            <strong>{{ stat.value }}</strong>
            <span>
              <span class="lang en">{{ stat.en }}</span>
              <span class="lang vi">{{ stat.vi }}</span>
              <span class="lang zh">{{ stat.zh }}</span>
            </span>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </aside>
    {% endif %}
  </div>
</section>

