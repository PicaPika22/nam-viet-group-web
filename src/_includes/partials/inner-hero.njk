{#
  Shared inner-page hero.
  Optional front matter / locals:
    eyebrow {en,vi,zh}
    heading {en,vi,zh}  OR title (string)
    lead {en,vi,zh}
    breadcrumb (string) — single trailing crumb
    breadcrumbHtml — raw HTML after Home (for article/product trails)
    heroTag — "section" (default) or "article"
    heroMeta — optional meta line (e.g. date)
#}
{% set tag = heroTag or "section" %}
<{{ tag }} class="inner-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ '/' | url }}">
        <span class="lang en">{{ i18n.en.breadcrumbHome }}</span>
        <span class="lang vi">{{ i18n.vi.breadcrumbHome }}</span>
        <span class="lang zh">{{ i18n.zh.breadcrumbHome }}</span>
      </a>
      {% if breadcrumbHtml %}
      {{ breadcrumbHtml | safe }}
      {% elif breadcrumb %}
      <span aria-hidden="true">/</span>
      <span>{{ breadcrumb }}</span>
      {% endif %}
    </nav>
    {% if eyebrow %}
    <p class="eyebrow">
      {% if eyebrow.en %}
      <span class="lang en">{{ eyebrow.en }}</span>
      <span class="lang vi">{{ eyebrow.vi }}</span>
      <span class="lang zh">{{ eyebrow.zh }}</span>
      {% else %}
      {{ eyebrow | safe }}
      {% endif %}
    </p>
    {% endif %}
    <h1 class="inner-hero__title">
      {% if heading %}
      <span class="lang en">{{ heading.en }}</span>
      <span class="lang vi">{{ heading.vi }}</span>
      <span class="lang zh">{{ heading.zh }}</span>
      {% elif title.en %}
      <span class="lang en">{{ title.en }}</span>
      <span class="lang vi">{{ title.vi }}</span>
      <span class="lang zh">{{ title.zh }}</span>
      {% else %}
      {{ title }}
      {% endif %}
    </h1>
    {% if lead %}
    <p class="inner-hero__lead">
      <span class="lang en">{{ lead.en }}</span>
      <span class="lang vi">{{ lead.vi }}</span>
      <span class="lang zh">{{ lead.zh }}</span>
    </p>
    {% endif %}
    {% if heroMeta %}
    <p class="inner-hero__meta">{{ heroMeta }}</p>
    {% endif %}
  </div>
</{{ tag }}>
