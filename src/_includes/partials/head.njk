{% set docTitle = site.title %}
{% if title %}
  {% if title.en or title.vi or title.zh %}
    {% set docTitle = (title.en or title.vi or title.zh) ~ " — " ~ site.name %}
  {% else %}
    {% set docTitle = title ~ " — " ~ site.name %}
  {% endif %}
{% endif %}
{% set docDesc = description or site.description %}
{% if docDesc.en or docDesc.vi or docDesc.zh %}
  {% set docDesc = docDesc.en or docDesc.vi or docDesc.zh %}
{% endif %}
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{{ docTitle }}</title>
<meta name="description" content="{{ docDesc }}">
<link rel="canonical" href="{{ page.url | absoluteUrl(site.url) }}">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ docTitle }}">
<meta property="og:description" content="{{ docDesc }}">
<meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}">
<meta property="og:image" content="{{ (ogImage or site.ogImage) | absoluteUrl(site.url) }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ docTitle }}">
<meta name="twitter:description" content="{{ docDesc }}">
<meta name="twitter:image" content="{{ (ogImage or site.ogImage) | absoluteUrl(site.url) }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="{{ '/assets/img/logo.png' | url }}">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
<link rel="stylesheet" href="{{ '/css/pages.css' | url }}">
{% if site.analyticsId %}
<script defer src="https://www.googletagmanager.com/gtag/js?id={{ site.analyticsId }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ site.analyticsId }}', { anonymize_ip: true });
</script>
{% endif %}
