<footer class="footer">
  <div class="container">
    <p class="footer__quote reveal">
      <span class="lang en">"Growing Sustainable Value Across Every Journey."</span>
      <span class="lang vi">"Kiến tạo giá trị bền vững trên mọi hành trình."</span>
      <span class="lang zh">"在每一段旅程中，创造可持续价值。"</span>
    </p>
    <div class="footer__grid">
      <div class="footer__brand">
        <img class="footer__logo" src="{{ '/assets/img/logo-light.png' | url }}" alt="Nam Viet Group logo">
        <p>NAM VIET GROUP</p>
      </div>
      <nav class="footer__nav">
        {% for item in nav.footer %}
        <a href="{{ item.href | url }}">
          <span class="lang en">{{ item.en }}</span>
          <span class="lang vi">{{ item.vi }}</span>
          <span class="lang zh">{{ item.zh }}</span>
        </a>
        {% endfor %}
      </nav>
      <div class="footer__contact">
        <p><a href="mailto:{{ site.emailPartner }}">{{ site.emailPartner }}</a></p>
        <p><a href="tel:{{ site.phoneTel }}">{{ site.phone }}</a></p>
        {% if site.phoneMobile %}
        <p><a href="tel:{{ site.phoneMobileTel }}">{{ site.phoneMobile }}</a></p>
        {% endif %}
        {% if site.taxId %}
        <p>
          <span class="lang en">Tax ID: {{ site.taxId }}</span>
          <span class="lang vi">MST: {{ site.taxId }}</span>
          <span class="lang zh">税号：{{ site.taxId }}</span>
        </p>
        {% endif %}
        <p>
          <span class="lang en">{{ site.address.en }}</span>
          <span class="lang vi">{{ site.address.vi }}</span>
          <span class="lang zh">{{ site.address.zh }}</span>
        </p>
      </div>
    </div>
    <p class="footer__copy">© 2026 Nam Viet Group.
      <span class="lang en">All rights reserved.</span>
      <span class="lang vi">Bảo lưu mọi quyền.</span>
      <span class="lang zh">保留所有权利。</span>
    </p>
  </div>
</footer>

<aside class="float-chat" aria-label="Liên hệ nhanh">
  <a class="float-chat__btn float-chat__btn--phone" href="tel:{{ site.phoneTel }}" title="Gọi {{ site.phone }}" aria-label="Gọi điện {{ site.phone }}">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.5 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
  </a>
  <a class="float-chat__btn float-chat__btn--zalo" href="https://zalo.me/{{ site.zalo }}" target="_blank" rel="noopener noreferrer" title="Chat Zalo" aria-label="Chat Zalo">
    <svg viewBox="0 0 48 48" aria-hidden="true"><path fill="currentColor" d="M24 4C12.95 4 4 12.42 4 22.8c0 5.7 2.9 10.8 7.45 14.2V44l7.05-3.85c1.75.5 3.6.75 5.5.75 11.05 0 20-8.42 20-18.8S35.05 4 24 4zm.7 25.9h-7.2l7.85-8.45c.55-.6.75-1.05.75-1.55 0-.9-.7-1.55-1.75-1.55h-8.7v2.55h6.85l-7.7 8.35c-.55.55-.8 1.05-.8 1.6 0 .9.7 1.55 1.8 1.55h8.95v-2.5zm10.15 0H27.5v-2.5h7.35v2.5z"/></svg>
  </a>
  <a class="float-chat__btn float-chat__btn--wa" href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer" title="Chat WhatsApp" aria-label="Chat WhatsApp">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17.5 14.3c-.3-.1-1.6-.8-1.9-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.8-.8-1.4-1.7-1.6-2-.1-.3 0-.4.1-.5.1-.1.3-.3.4-.4.1-.1.2-.3.3-.4.1-.2 0-.3 0-.4 0-.1-.6-1.5-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.4.1-.7.4-.2.3-.9.9-.9 2.1s.9 2.4 1 2.6c.1.2 1.8 2.8 4.4 3.8 1.5.6 2.1.7 2.9.6.4-.1 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1-.1-.1-.2-.2-.5-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3c1.4.8 3.1 1.3 4.8 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3.1.8.8-3-.2-.3C4.1 15.1 3.6 13.6 3.6 12 3.6 7.4 7.4 3.6 12 3.6S20.4 7.4 20.4 12 16.6 20.2 12 20.2z"/></svg>
  </a>
</aside>

<div class="cookie-bar" id="cookieBar" hidden role="dialog" aria-labelledby="cookieBarTitle" aria-live="polite">
  <div class="cookie-bar__content">
    <p class="cookie-bar__title" id="cookieBarTitle">
      <span class="lang en">{{ i18n.en.cookieTitle }}</span>
      <span class="lang vi">{{ i18n.vi.cookieTitle }}</span>
      <span class="lang zh">{{ i18n.zh.cookieTitle }}</span>
    </p>
    <p class="cookie-bar__text">
      <span class="lang en">{{ i18n.en.cookieText }}</span>
      <span class="lang vi">{{ i18n.vi.cookieText }}</span>
      <span class="lang zh">{{ i18n.zh.cookieText }}</span>
      <a href="{{ '/cookies/' | url }}">
        <span class="lang en">{{ i18n.en.cookiePolicy }}</span>
        <span class="lang vi">{{ i18n.vi.cookiePolicy }}</span>
        <span class="lang zh">{{ i18n.zh.cookiePolicy }}</span>
      </a>
    </p>
  </div>
  <div class="cookie-bar__actions">
    <button type="button" class="cookie-bar__btn cookie-bar__btn--decline" id="cookieDecline">
      <span class="lang en">{{ i18n.en.cookieDecline }}</span>
      <span class="lang vi">{{ i18n.vi.cookieDecline }}</span>
      <span class="lang zh">{{ i18n.zh.cookieDecline }}</span>
    </button>
    <button type="button" class="cookie-bar__btn cookie-bar__btn--accept" id="cookieAccept">
      <span class="lang en">{{ i18n.en.cookieAccept }}</span>
      <span class="lang vi">{{ i18n.vi.cookieAccept }}</span>
      <span class="lang zh">{{ i18n.zh.cookieAccept }}</span>
    </button>
  </div>
</div>
