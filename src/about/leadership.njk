---
pagination:
  data: leadership
  size: 1
  alias: person
permalink: "/about/leadership/{{ person.id }}/"
layout: layouts/inner.njk
eleventyComputed:
  title: "{{ person.name.en }}"
  eyebrow:
    en: Leadership
    vi: Ban lãnh đạo
    zh: 领导团队
  heading:
    en: "{{ person.name.en }}"
    vi: "{{ person.name.vi }}"
    zh: "{{ person.name.zh }}"
  lead:
    en: "{{ person.role.en }}"
    vi: "{{ person.role.vi }}"
    zh: "{{ person.role.zh }}"
---

<article class="leader-profile">
  <nav class="breadcrumb leader-profile__crumb" aria-label="Breadcrumb">
    <a href="{{ '/' | url }}">
      <span class="lang en">{{ i18n.en.breadcrumbHome }}</span>
      <span class="lang vi">{{ i18n.vi.breadcrumbHome }}</span>
      <span class="lang zh">{{ i18n.zh.breadcrumbHome }}</span>
    </a>
    <span aria-hidden="true">/</span>
    <a href="{{ '/about/#leadership' | url }}">
      <span class="lang en">Leadership</span>
      <span class="lang vi">Ban lãnh đạo</span>
      <span class="lang zh">领导团队</span>
    </a>
    <span aria-hidden="true">/</span>
    <span>
      <span class="lang en">{{ person.name.en }}</span>
      <span class="lang vi">{{ person.name.vi }}</span>
      <span class="lang zh">{{ person.name.zh }}</span>
    </span>
  </nav>

  <div class="leader-profile__panel">
    <div class="leader-profile__media">
      <img
        src="{{ person.image | url }}"
        alt="{{ person.name.en }}"
        width="480"
        height="640"
        loading="eager"
        decoding="async"
      >
    </div>
    <div class="leader-profile__body">
      <p class="leader-profile__role">
        <span class="lang en">{{ person.role.en }}</span>
        <span class="lang vi">{{ person.role.vi }}</span>
        <span class="lang zh">{{ person.role.zh }}</span>
      </p>
      <h2 class="leader-profile__name visually-hidden">
        <span class="lang en">{{ person.name.en }}</span>
        <span class="lang vi">{{ person.name.vi }}</span>
        <span class="lang zh">{{ person.name.zh }}</span>
      </h2>
      {% if person.bio %}
      <blockquote class="leader-profile__bio">
        <p>
          <span class="lang en">{{ person.bio.en }}</span>
          <span class="lang vi">{{ person.bio.vi }}</span>
          <span class="lang zh">{{ person.bio.zh }}</span>
        </p>
      </blockquote>
      {% endif %}
      <p class="page-actions">
        <a class="btn btn--outline btn--dark" href="{{ '/about/#leadership' | url }}">
          <span class="lang en">Back to leadership</span>
          <span class="lang vi">Về ban lãnh đạo</span>
          <span class="lang zh">返回领导团队</span>
        </a>
        <a class="btn btn--solid" href="{{ '/contact/' | url }}">
          <span class="lang en">{{ i18n.en.contact }}</span>
          <span class="lang vi">{{ i18n.vi.contact }}</span>
          <span class="lang zh">{{ i18n.zh.contact }}</span>
        </a>
      </p>
    </div>
  </div>

  <section class="leader-profile__more" aria-labelledby="more-leaders">
    <h3 id="more-leaders">
      <span class="lang en">Other leaders</span>
      <span class="lang vi">Các lãnh đạo khác</span>
      <span class="lang zh">其他领导</span>
    </h3>
    <ul class="leader-grid leader-grid--compact">
      {% for p in leadership %}
      {% if p.id != person.id %}
      <li>
        <a class="leader-card" href="{{ ('/about/leadership/' + p.id + '/') | url }}">
          <div class="leader-card__media">
            <img src="{{ p.image | url }}" alt="" loading="lazy" width="320" height="400">
          </div>
          <span class="leader-card__name">
            <span class="lang en">{{ p.name.en }}</span>
            <span class="lang vi">{{ p.name.vi }}</span>
            <span class="lang zh">{{ p.name.zh }}</span>
          </span>
          <span class="leader-card__role">
            <span class="lang en">{{ p.role.en }}</span>
            <span class="lang vi">{{ p.role.vi }}</span>
            <span class="lang zh">{{ p.role.zh }}</span>
          </span>
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>
  </section>
</article>
