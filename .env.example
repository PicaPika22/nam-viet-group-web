# ── Railway Content Studio ──
# Copy to Railway Variables (do not commit real secrets)

# Railway sets PORT automatically
HOST=0.0.0.0

# GitHub Contents API — commits markdown so Vercel rebuilds
GITHUB_TOKEN=ghp_xxxxxxxx
GITHUB_REPO=PicaPika22/nam-viet-group-web
GITHUB_BRANCH=main

# Protect the CMS (required in production)
ADMIN_USER=editor
ADMIN_PASS=change-me-strong-password
# Optional instead of user/pass:
# ADMIN_TOKEN=long-random-string

# Public website URL (link “Xem website” in Studio)
SITE_URL=https://nam-viet-group-web.vercel.app

# Optional: restrict browser origins
CORS_ORIGIN=*
